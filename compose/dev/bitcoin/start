#!/bin/sh
set -e

# 后台启动 bitcoind（参数已在 bitcoin.conf 中配置）
bitcoind &
BITCOIND_PID=$!
trap "kill $BITCOIND_PID; wait $BITCOIND_PID; exit 0" TERM INT

BTC="bitcoin-cli -regtest -rpcuser=xcash -rpcpassword=xcash"

echo "等待 bitcoind 就绪..."
until $BTC getblockchaininfo > /dev/null 2>&1; do
  kill -0 $BITCOIND_PID 2>/dev/null || exit 1
  sleep 1
done

# 创建或加载 miner 钱包
$BTC createwallet "miner" > /dev/null 2>&1 || \
$BTC loadwallet "miner" > /dev/null 2>&1 || true

# 固定挖矿地址，避免每次重启生成新地址导致奖励分散
ADDR_FILE="/root/.bitcoin/regtest/miner_address"
if [ -f "$ADDR_FILE" ]; then
  ADDR=$(cat "$ADDR_FILE")
else
  ADDR=$($BTC -rpcwallet=miner getnewaddress "mining")
  echo "$ADDR" > "$ADDR_FILE"
fi
echo "挖矿地址: $ADDR"

# 每 5 秒自动出块
while kill -0 $BITCOIND_PID 2>/dev/null; do
  $BTC -rpcwallet=miner generatetoaddress 1 "$ADDR" > /dev/null 2>&1
  sleep "${LOCAL_BTC_BLOCK_INTERVAL:-5}"
done
